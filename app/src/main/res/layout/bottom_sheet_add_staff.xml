<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#FFD9D9D9"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tvBottomSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:text="@string/str_no_data"
            android:textColor="@color/clr_text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Staff Email using OutlinedBox for consistency -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/str_hint_email"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:textColorHint="#757575"
            app:hintTextColor="@color/clr_primary_blue"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:startIconDrawable="@drawable/ic_auth_email">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStaffEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/clr_text_black"
                android:textSize="16sp"
                android:inputType="textEmailAddress"
                android:imeOptions="actionDone"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Warning info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_info"
                app:tint="@color/clr_grey_1"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu ý: Nhân sự cần có tài khoản VibeTix từ trước."
                android:textColor="@color/clr_grey_1"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_discount_type"
            android:textColor="@color/clr_text_black"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rgStaffRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbRoleManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/role_manager"
                android:textColor="@color/clr_text_black"
                android:textSize="15sp"
                android:textStyle="bold"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toàn quyền quản lý loại vé, xem doanh thu, gửi thông báo và cấu hình sự kiện."
                android:textSize="13sp"
                android:textColor="@color/clr_text_secondary"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="16dp"/>

            <RadioButton
                android:id="@+id/rbRoleScanner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/role_staff"
                android:textColor="@color/clr_text_black"
                android:textSize="15sp"
                android:textStyle="bold" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chỉ có quyền sử dụng máy quét QR tại sự kiện và xem danh sách người tham dự."
                android:textSize="13sp"
                android:textColor="@color/clr_text_secondary"
                android:layout_marginStart="32dp"/>
        </RadioGroup>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveStaff"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/str_confirm"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/clr_text_white"
            app:backgroundTint="@color/clr_primary"
            app:cornerRadius="12dp" />

    </LinearLayout>
</LinearLayout>

