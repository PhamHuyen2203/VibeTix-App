<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm nhân sự"
        android:textColor="@color/clr_text_black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Staff Email -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="1dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etStaffEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email tài khoản VibeTix"
            android:inputType="textEmailAddress"
            android:background="@color/clr_bg_light" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lưu ý: Nhân sự cần có tài khoản VibeTix từ trước."
        android:textColor="@color/clr_grey_1"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vai trò (Role)"
        android:textColor="@color/clr_text_black"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgStaffRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rbRoleManager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quản lý (MANAGER)"
            android:textColor="@color/clr_text_black" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Có thể quản lý vé, xem doanh thu, thống kê"
            android:textSize="12sp"
            android:textColor="@color/clr_grey_1"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="8dp"/>

        <RadioButton
            android:id="@+id/rbRoleScanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soát vé (SCANNER)"
            android:textColor="@color/clr_text_black" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chỉ có quyền sử dụng QR Scanner tại sự kiện"
            android:textSize="12sp"
            android:textColor="@color/clr_grey_1"
            android:layout_marginStart="32dp"/>
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveStaff"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Thêm nhân sự"
        android:textColor="@color/clr_text_white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/clr_primary"
        app:cornerRadius="12dp" />

</LinearLayout>
