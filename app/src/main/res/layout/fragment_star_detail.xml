<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Top Floating Header Bar -->
    <LinearLayout
        android:id="@+id/layoutStarHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="4dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnStarBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/txtHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_star_detail_title"
                android:textColor="@color/clr_text_black"
                android:textSize="18sp" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Scrollable Profile Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutStarHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Header Container (Cover + Avatar + Main Info) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/clr_bg_white"
                android:paddingBottom="16dp">

                <!-- Cover Image -->
                <ImageView
                    android:id="@+id/imvStarCover"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/banner_promo_30off" />

                <!-- Circular Avatar (Overlapping cover bottom) -->
                <ImageView
                    android:id="@+id/imvStarAvatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginTop="96dp"
                    android:layout_marginStart="20dp"
                    android:padding="3dp"
                    android:background="@color/clr_bg_white"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_mascot_wave" />

                <!-- Follow Button (Right aligned next to cover bottom) -->
                <Button
                    android:id="@+id/btnFollowStar"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="148dp"
                    android:layout_marginEnd="20dp"
                    android:backgroundTint="@color/clr_btn_blue"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="16dp"
                    android:text="@string/str_follow_action"
                    android:textColor="@color/clr_text_white"
                    android:textSize="13sp"
                    app:cornerRadius="20dp" />

                <!-- Stage Name & Details -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/imvStarAvatar"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtStarStageName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-bold"
                            android:text="@string/str_loading_placeholder"
                            android:textColor="@color/clr_text_black"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/imvStarVerified"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_check"
                            app:tint="@color/clr_primary_blue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtStarSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif"
                        android:text=""
                        android:textColor="@color/clr_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtStarFollowers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="0 người theo dõi"
                        android:textColor="@color/clr_primary_blue"
                        android:textSize="13sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Bio Card Section (if available) -->
            <LinearLayout
                android:id="@+id/layoutStarBioSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/clr_bg_white"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/str_intro_section"
                    android:textColor="@color/clr_text_black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtStarBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingMultiplier="1.2"
                    android:text="@string/str_no_artist_bio"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Activities & Performing Events Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/clr_bg_white"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/str_artist_events_section"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Loading Spinner -->
                <ProgressBar
                    android:id="@+id/pbStarEventsLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:visibility="visible" />

                <!-- Empty Events Label -->
                <TextView
                    android:id="@+id/txtStarEventsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/str_no_artist_events"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Events List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStarEvents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

