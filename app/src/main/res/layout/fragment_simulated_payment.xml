<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Top Toolbar Header -->
    <RelativeLayout
        android:id="@+id/layoutPaymentHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnPaymentBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-medium"
            android:text="Thanh toán"
            android:textColor="@color/clr_text_black"
            android:textSize="18sp" />
    </RelativeLayout>

    <!-- Progress Step Indicator Bar -->
    <LinearLayout
        android:id="@+id/layoutPaymentProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutPaymentHeader">

        <!-- Step 1 (Completed) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:padding="4dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/clr_text_white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn vé"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_primary_blue" />

        <!-- Step 2 (Completed) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:padding="4dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/clr_text_white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thông tin"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_primary_blue" />

        <!-- Step 3 (Active) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/clr_text_white"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thanh toán"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_divider" />

        <!-- Step 4 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hoàn tất"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable checkout info -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/layoutPaymentBottomBar"
        app:layout_constraintTop_toBottomOf="@+id/layoutPaymentProgress">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Countdown Timer Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_quick_chip"
                android:backgroundTint="@color/clr_bg_section"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar_small"
                    app:tint="@color/clr_primary_blue" />

                <TextView
                    android:id="@+id/txtPaymentCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Vui lòng hoàn tất đặt vé trong  14 : 59"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Event Card Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imvPaymentEventThumb"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/event_live_non_song"
                        app:cornerRadius="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtPaymentEventTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:text="LUNCH &amp; LEARN: Workshop về Phỏng vấn Ứng viên"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtPaymentEventDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="09:00 - 12:00, 23 May, 2026"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtPaymentEventLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="WB Business Center, Quận 3, TP. Hồ Chí Minh"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ticket Receiver Block -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icPaymentMail"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerInParent="true"
                        android:background="@drawable/bg_quick_chip"
                        android:padding="10dp"
                        android:src="@drawable/ic_auth_email"
                        app:tint="@color/clr_primary_blue" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@+id/icPaymentMail"
                        android:layout_toStartOf="@+id/btnPaymentEditEmail"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông tin nhận vé"
                            android:textColor="@color/clr_text_black"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtPaymentReceiverEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="user@gmail.com"
                            android:textColor="@color/clr_primary_blue"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnPaymentEditEmail"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/clr_grey_1" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Voucher Code Entry -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerInParent="true"
                        android:fontFamily="sans-serif-medium"
                        android:text="🎟  Mã giảm giá / Voucher"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/txtPaymentAppliedVoucher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerInParent="true"
                        android:text="Nhập mã giảm giá ›"
                        android:textColor="@color/clr_grey_2"
                        android:textSize="13sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Payment Methods Block -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="Phương thức thanh toán bảo mật"
                android:textColor="@color/clr_text_black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <RadioGroup
                    android:id="@+id/rgPaymentMethods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- VNPay -->
                    <RadioButton
                        android:id="@+id/rbVNPay"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:checked="true"
                        android:fontFamily="sans-serif"
                        android:paddingStart="12dp"
                        android:text="Cổng thanh toán VNPay (Thanh toán qua ứng dụng ngân hàng)"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clr_divider" />

                    <!-- VietQR -->
                    <RadioButton
                        android:id="@+id/rbVietQR"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:fontFamily="sans-serif"
                        android:paddingStart="12dp"
                        android:text="Chuyển khoản VietQR (Quét mã QR để thanh toán)"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clr_divider" />

                    <!-- ZaloPay -->
                    <RadioButton
                        android:id="@+id/rbZaloPay"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:fontFamily="sans-serif"
                        android:paddingStart="12dp"
                        android:text="Ví điện tử ZaloPay"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clr_divider" />

                    <!-- ShopeePay -->
                    <RadioButton
                        android:id="@+id/rbShopeePay"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:fontFamily="sans-serif"
                        android:paddingStart="12dp"
                        android:text="Ví điện tử ShopeePay"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clr_divider" />

                    <!-- Credit Card -->
                    <RadioButton
                        android:id="@+id/rbCreditCard"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:fontFamily="sans-serif"
                        android:paddingStart="12dp"
                        android:text="Thẻ quốc tế Visa, Mastercard, JCB (Sắp ra mắt)"
                        android:textColor="@color/clr_grey_1"
                        android:enabled="false"
                        android:textSize="13sp" />
                </RadioGroup>
            </androidx.cardview.widget.CardView>

            <!-- Order pricing summary block -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Tóm tắt đơn hàng"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <TextView
                            android:id="@+id/txtPaymentSummaryName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vé Tiêu chuẩn x1"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txtPaymentSummaryPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="400.000 đ"
                            android:textColor="@color/clr_text_black"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phí nền tảng ℹ"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txtPaymentSummaryFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="10.000 đ"
                            android:textColor="@color/clr_text_black"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giảm giá"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/txtPaymentSummaryDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="- 0 đ"
                            android:textColor="@color/clr_green"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/clr_divider" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Tổng cộng"
                            android:textColor="@color/clr_text_black"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/txtPaymentSummaryTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="sans-serif-medium"
                            android:text="410.000 đ"
                            android:textColor="@color/clr_primary_blue"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Legal terms agreement -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <CheckBox
                    android:id="@+id/cbPaymentAgree"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:checked="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Tôi đã đọc và đồng ý với Quy chế hoạt động của VibeTix và Chính sách bảo mật."
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom simulated payment actions -->
    <LinearLayout
        android:id="@+id/layoutPaymentBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng thanh toán"
                android:textColor="@color/clr_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtPaymentBottomTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="410.000 đ"
                android:textColor="@color/clr_primary_blue"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnPaymentPay"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="@color/clr_btn_blue"
            android:fontFamily="sans-serif-medium"
            android:text="Thanh toán 🔒"
            android:textColor="@color/clr_text_white"
            android:textSize="14sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
