<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Ảnh banner lớn -->
    <ImageView
        android:id="@+id/imgPromoDialogBanner"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/banner_promo_30off"
        android:contentDescription="@null" />

    <!-- Nội dung -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_pending"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="@string/str_promo_badge"
            android:textColor="#E6B93E"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_promo_discount_headline"
            android:textColor="#1C1B1B"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_promo_discount_condition"
            android:textColor="#226CEB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- Chi tiết ưu đãi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_section_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/str_promo_conditions_header"
                android:textColor="#808E92" android:textSize="11sp" android:textStyle="bold"
                android:letterSpacing="0.05" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/str_promo_condition_1"
                android:textColor="#1C1B1B" android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/str_promo_condition_2"
                android:textColor="#1C1B1B" android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/str_promo_condition_3"
                android:textColor="#1C1B1B" android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/str_promo_expiry"
                android:textColor="#EB5757" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Nút hành động -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPromoDialogClose"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:text="@string/str_promo_dismiss_btn"
                android:textColor="#808E92"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnPromoDialogGo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="@string/str_promo_claim_btn"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

