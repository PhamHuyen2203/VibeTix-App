<?xml version="1.0" encoding="utf-8"?>
<!--
  Outer LinearLayout (vertical, wrap_content):
    - NO fitsSystemWindows here — using it on a LinearLayout applies ALL insets
      (top + bottom + left + right) as padding, which incorrectly adds
      paddingBottom = gesture-bar height and creates an unwanted blue gap at the
      bottom of the header.
    - Top inset (status-bar height) is applied programmatically in HomeFragment
      via ViewCompat.setOnApplyWindowInsetsListener so ONLY paddingTop is set.
    - animateLayoutChanges="true" → smooth toggle between default and search rows
    - Blue background extends behind status bar (seamless EdgeToEdge look)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:background="@color/clr_primary_blue"
    android:elevation="4dp"
    android:orientation="vertical">

    <!-- ── DEFAULT ROW: logo + search icon + notification ── -->
    <LinearLayout
        android:id="@+id/rowHeaderDefault"
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingStart="@dimen/spacing_lg">

        <!--
          Logo: wrap_content width so adjustViewBounds shrinks it to the image's
          aspect ratio (≈ 1:1 PNG).  match_parent height fills the full 72dp row,
          giving the square ~72dp display size so "VibeTix" is clearly readable.
          A zero-weight spacer View between the logo and the icons pushes the
          icons to the right without needing layout_weight on the ImageView
          (which fights with adjustViewBounds).
        -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="@string/str_cd_app_logo"
            android:scaleType="fitStart"
            android:src="@drawable/ic_vibetix_logo_full" />

        <!-- Flexible spacer — pushes search + notification to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Search icon button — id kept for HomeFragment.layoutSearchBar click listener -->
        <LinearLayout
            android:id="@+id/layoutSearchBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_sm">

            <ImageView
                android:layout_width="@dimen/header_icon_size"
                android:layout_height="@dimen/header_icon_size"
                android:contentDescription="@string/str_cd_search"
                android:src="@drawable/ic_search"
                android:tint="@color/clr_text_white" />
        </LinearLayout>

        <!-- Notification icon button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_sm">

            <ImageView
                android:id="@+id/imgBtnNotification"
                android:layout_width="@dimen/header_icon_size"
                android:layout_height="@dimen/header_icon_size"
                android:contentDescription="@string/str_cd_notification"
                android:src="@drawable/ic_notification"
                android:tint="@color/clr_text_white" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── EXPANDED SEARCH ROW: close + EditText (GONE by default) ── -->
    <LinearLayout
        android:id="@+id/rowSearchExpanded"
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="@dimen/spacing_base"
        android:paddingStart="@dimen/spacing_sm"
        android:visibility="gone">

        <!-- Close / back button (✕) -->
        <TextView
            android:id="@+id/btnSearchBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/clr_text_white"
            android:textSize="@dimen/text_lg" />

        <!-- Search input field -->
        <EditText
            android:id="@+id/etSearchQuery"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:hint="@string/str_search_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:paddingEnd="@dimen/spacing_base"
            android:paddingStart="@dimen/spacing_base"
            android:singleLine="true"
            android:textColor="@color/clr_text_black"
            android:textColorHint="@color/clr_grey_1"
            android:textSize="@dimen/text_base" />
    </LinearLayout>

</LinearLayout>
