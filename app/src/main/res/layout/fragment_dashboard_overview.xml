<?xml version="1.0" encoding="utf-8"?>
<!--
  Organizer Dashboard Fragment — Premium Redesign (Phase 2)
  Structure:
    1. CoordinatorLayout root
    2. AppBarLayout → CollapsingToolbarLayout with gradient header
       - Greeting text + Organizer name
       - Stats row (Revenue / Tickets / Check-in today) as white cards
    3. NestedScrollView (appbar_scrolling_view_behavior)
       - Quick Actions 2×3 grid
       - Recent Events section + RecyclerView
    4. ExtendedFAB (Create Event) pinned at bottom-right
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- ══════════════════════════════════════════════════
         APP BAR — Collapsing header with gradient
         ══════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_primary_blue"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/clr_primary_blue"
            app:titleEnabled="false">

            <!-- Gradient background fills the entire collapsing area -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_dashboard_header_gradient"
                app:layout_collapseMode="parallax" />

            <!-- Header content: greeting + organizer name + stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp"
                app:layout_collapseMode="parallax">

                <!-- Top row: Greeting left, Notification icon right -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDashGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chào buổi tối! 👋"
                            android:textColor="@color/clr_text_white"
                            android:textSize="13sp"
                            android:alpha="0.85" />

                        <TextView
                            android:id="@+id/tvDashOrgName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ban tổ chức"
                            android:textColor="@color/clr_text_white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            tools:text="VibeTix Productions" />

                    </LinearLayout>

                    <!-- Notification bell -->
                    <LinearLayout
                        android:id="@+id/btnOrgNotification"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_notification"
                            android:tint="@color/clr_text_white"
                            android:contentDescription="@string/str_notification" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Stats Row: 3 white semi-transparent cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:weightSum="3">

                    <!-- Stat 1: Revenue -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_organizer_stats_card"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tvStatRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/clr_text_white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="150M" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Doanh thu"
                            android:textColor="#CCE8F4"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Stat 2: Tickets sold -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_organizer_stats_card"
                        android:padding="14dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp">

                        <TextView
                            android:id="@+id/tvStatTickets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/clr_text_white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="850" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Vé bán"
                            android:textColor="#CCE8F4"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Stat 3: Check-ins today -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_organizer_stats_card"
                        android:padding="14dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:id="@+id/tvStatCheckins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/clr_text_white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="342" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Check-in hôm nay"
                            android:textColor="#CCE8F4"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Collapsed Toolbar (shows when scrolled up) -->
            <androidx.appcompat.widget.Toolbar
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:title="Dashboard"
                app:titleTextColor="@color/clr_text_white" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════════
         SCROLLABLE BODY
         ══════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- ── SECTION: Thao tác nhanh ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thao tác nhanh"
                android:textColor="@color/clr_text_black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Quick Actions Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="10dp">

                <!-- Card: Tạo sự kiện -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCreateEvent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗓️"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Tạo sự kiện"
                            android:textColor="@color/clr_text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Sự kiện của tôi -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMyEvents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Sự kiện của tôi"
                            android:textColor="@color/clr_text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Doanh thu -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRevenue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Doanh thu"
                            android:textColor="@color/clr_text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Quick Actions Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="24dp">

                <!-- Card: Nhân sự -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStaff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Nhân sự"
                            android:textColor="@color/clr_text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Loại vé -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTicketTypes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎫"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Loại vé"
                            android:textColor="@color/clr_text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Thông báo -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardNotification"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔔"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Thông báo"
                            android:textColor="@color/clr_text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── SECTION: Sự kiện gần đây ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sự kiện gần đây"
                    android:textColor="@color/clr_text_black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtViewAllEvents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="13sp"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- Recent Events RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_event_dashboard" />

            <!-- Empty state for recent events -->
            <LinearLayout
                android:id="@+id/layoutEmptyEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗓️"
                    android:textSize="48sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Chưa có sự kiện nào"
                    android:textColor="@color/clr_text_black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Nhấn nút + để tạo sự kiện đầu tiên"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="13sp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════
         EXTENDED FAB — Create Event
         ══════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabCreateEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="Tạo sự kiện"
        android:textColor="@color/clr_text_white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/clr_text_white"
        app:backgroundTint="@color/clr_primary_blue"
        app:elevation="6dp"
        app:layout_anchor="@id/rvRecentEvents"
        app:layout_anchorGravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
