<?xml version="1.0" encoding="utf-8"?>
<!--
  User Profile Fragment Layout
  Design: Blue header with avatar and name, white scrollable body with info cards.
  Matches IDs used in ProfileFragment.java
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light"
    android:orientation="vertical">

    <!-- ═══ BLUE HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_primary_blue"
        android:elevation="4dp"
        android:orientation="vertical">

        <!-- Top bar: Logo + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="12dp"
            android:paddingStart="20dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="@string/str_cd_app_logo"
                android:scaleType="fitStart"
                android:src="@drawable/ic_vibetix_logo_full" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_nav_profile"
                android:textColor="@color/clr_text_white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingEnd="8dp" />
        </LinearLayout>

        <!-- Avatar + Name + Edit Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="28dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivProfileAvatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_nav_profile"
                    android:contentDescription="@null" />

                <ImageButton
                    android:id="@+id/btnEditProfile"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/clr_bg_white"
                    android:src="@drawable/ic_chevron_right"
                    android:padding="6dp"
                    app:tint="@color/clr_primary_blue"
                    android:elevation="2dp"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/clr_text_white"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Nguyễn Văn A" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ WHITE SCROLLABLE BODY ═══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── INFO CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Email row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_auth_email"
                            app:tint="@color/clr_primary_blue"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            tools:text="user@example.com" />
                    </LinearLayout>

                    <!-- Phone row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_auth_phone"
                            app:tint="@color/clr_primary_blue"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvProfilePhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            tools:text="0987 654 321" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ORGANIZER PROFILES CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutOrganizerProfiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hồ sơ Ban tổ chức"
                        android:textColor="@color/clr_text_black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOrgProfileCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/clr_grey_1"
                        android:textSize="13sp"
                        tools:text="Chưa có hồ sơ Ban tổ chức" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddOrganizer"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="+ Thêm hồ sơ"
                        android:textAllCaps="false"
                        android:textColor="@color/clr_primary_blue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SETTINGS CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/btnNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="16dp"
                        android:text="Thông báo"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="@color/clr_grey_1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clr_divider" />

                    <TextView
                        android:id="@+id/btnTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="16dp"
                        android:text="Điều khoản sử dụng"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="@color/clr_grey_1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clr_divider" />

                    <TextView
                        android:id="@+id/btnSupport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="16dp"
                        android:text="Liên hệ hỗ trợ"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="@color/clr_grey_1" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── LOGOUT BUTTON ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="@string/str_logout"
                android:textAllCaps="false"
                android:textColor="@color/clr_error"
                android:textSize="15sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/clr_bg_white"
                app:strokeColor="@color/clr_error"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
