<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_form_card">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/str_notification_popup_title"
            android:textColor="@color/clr_text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseSheet"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:padding="4dp"
            android:contentDescription="@null" />
    </LinearLayout>

    <!-- Tiêu đề -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Style.VibeTix.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tiêu đề thông báo"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Nội dung -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Style.VibeTix.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nội dung thông báo"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:maxLines="6"
            android:gravity="top" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Đối tượng gửi -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gửi tới"
        android:textColor="@color/clr_text_black"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgTarget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rbAllBuyers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_all"
            android:checked="true"
            android:textColor="@color/clr_text_black"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbConfirmedOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chỉ vé đã xác nhận"
            android:textColor="@color/clr_text_black"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbTicketType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Theo loại vé"
            android:textColor="@color/clr_text_black"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- Chọn loại vé (ẩn mặc định) -->
    <LinearLayout
        android:id="@+id/layoutTicketType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Chọn loại vé">

            <AutoCompleteTextView
                android:id="@+id/ddTicketType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Nút gửi -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendBlast"
        style="@style/Style.VibeTix.Button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/str_notification_popup_title"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>

