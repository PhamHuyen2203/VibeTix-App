<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Drag handle indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_drag_handle"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chuyển Ban tổ chức"
        android:textColor="@color/clr_text_black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrganizerList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/clr_divider" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddOrganizer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="+ Thêm Ban tổ chức mới"
        android:layout_margin="16dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
