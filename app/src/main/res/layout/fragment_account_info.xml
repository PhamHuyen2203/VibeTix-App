<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF9F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ BLUE HEADER ══ -->
            <LinearLayout
                android:id="@+id/layoutAccountInfoHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_auth_header"
                android:orientation="vertical"
                android:paddingTop="32dp">

                <!-- Toolbar row: back + title -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="4dp"
                        android:padding="10dp"
                        android:background="@drawable/bg_back_btn"
                        android:src="@drawable/ic_back"
                        android:contentDescription="Quay lại" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Thông tin tài khoản"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Spacer trước avatar -->
                <View android:layout_width="match_parent" android:layout_height="8dp" />

                <!-- Avatar + camera button -->
                <FrameLayout
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/imgAccountAvatar"
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:padding="3dp"
                        android:src="@drawable/img_mascot_normal"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:id="@+id/btnCameraAvatar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:background="#226CEB"
                        android:gravity="center"
                        android:elevation="2dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_camera"
                            android:contentDescription="Chọn ảnh" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Bottom padding inside header -->
                <View android:layout_width="match_parent" android:layout_height="16dp" />

            </LinearLayout>

            <!-- ══ FORM CARD ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_section_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Họ và tên -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Họ và tên"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/containerFullName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_normal"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_auth_person"
                        android:tint="#808E92"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtFullName"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Nhập họ và tên"
                        android:inputType="textPersonName|textCapWords"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="#1C1B1B"
                        android:textColorHint="@color/clr_grey_2"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Email — readonly -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Email"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="#F4F4F8"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_auth_email"
                        android:tint="#B0B8C1"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="email@example.com"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:cursorVisible="false"
                        android:textColor="#B0B8C1"
                        android:textColorHint="#C0C8D0"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status_approved"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="Đã xác minh"
                        android:textColor="#27AE60"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Số điện thoại -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Số điện thoại"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/containerPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_normal"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_auth_phone"
                        android:tint="#808E92"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtPhone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="0xxxxxxxxx"
                        android:inputType="phone"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="#1C1B1B"
                        android:textColorHint="@color/clr_grey_2"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Ngày sinh -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Ngày sinh"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/containerDob"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_normal"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_notification"
                        android:tint="#808E92"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edtDob"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="dd/mm/yyyy"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:cursorVisible="false"
                        android:textColor="#1C1B1B"
                        android:textColorHint="@color/clr_grey_2"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Giới tính -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="10dp"
                    android:text="Giới tính"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbMale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:buttonTint="@color/clr_primary_blue"
                        android:text="Nam"
                        android:textColor="#1C1B1B"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rbFemale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:buttonTint="@color/clr_primary_blue"
                        android:text="Nữ"
                        android:textColor="#1C1B1B"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rbOther"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/clr_primary_blue"
                        android:text="Khác"
                        android:textColor="#1C1B1B"
                        android:textSize="14sp" />
                </RadioGroup>

            </LinearLayout>

            <!-- ══ SAVE BUTTON ══ -->
            <Button
                android:id="@+id/btnSaveInfo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Lưu thay đổi"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
