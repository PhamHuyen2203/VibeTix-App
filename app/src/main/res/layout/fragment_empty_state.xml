<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_empty_mascot"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@mipmap/ic_mascot_search_no_background" />

    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Nothing here yet!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/clr_grey_1" />

    <TextView
        android:id="@+id/tv_empty_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="We couldn't find any data to display."
        android:textColor="@color/clr_grey_2" />

</LinearLayout>
