<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#E0E0E0" />

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_filter_title_dialog"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="#1C1B1B" />

            <TextView
                android:id="@+id/btnFilterClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textSize="18sp"
                android:textColor="#1C1B1B"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8ECF0" />

        <!-- Location section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_filter_location"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1C1B1B"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbNational"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_all_nation"
                    android:textSize="14sp"
                    android:textColor="#1C1B1B"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:checked="true"
                    android:buttonTint="#226CEB" />

                <RadioButton
                    android:id="@+id/rbHCMC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_hcmc"
                    android:textSize="14sp"
                    android:textColor="#1C1B1B"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:buttonTint="#226CEB" />

                <RadioButton
                    android:id="@+id/rbHanoi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_hanoi"
                    android:textSize="14sp"
                    android:textColor="#1C1B1B"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:buttonTint="#226CEB" />

                <RadioButton
                    android:id="@+id/rbDaLat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_dalat"
                    android:textSize="14sp"
                    android:textColor="#1C1B1B"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:buttonTint="#226CEB" />

                <RadioButton
                    android:id="@+id/rbDaNang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_danang"
                    android:textSize="14sp"
                    android:textColor="#1C1B1B"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:buttonTint="#226CEB" />

            </RadioGroup>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8ECF0" />

        <!-- Price section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_filter_price"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1C1B1B"
                android:layout_marginBottom="8dp" />

            <!-- Free-only toggle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/str_filter_free_only_label"
                    android:textSize="14sp"
                    android:textColor="#1C1B1B" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchFreeOnly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="#226CEB"
                    app:trackTint="#90B4F5" />

            </LinearLayout>

            <!-- Price range slider — hidden when free-only is ON -->
            <LinearLayout
                android:id="@+id/layoutPriceRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Min / Max labels row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/txtMinPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0đ"
                        android:textSize="12sp"
                        android:textColor="#226CEB"
                        android:textStyle="bold"
                        android:background="@drawable/bg_price_tag"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/txtMaxPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.000.000+đ"
                        android:textSize="12sp"
                        android:textColor="#226CEB"
                        android:textStyle="bold"
                        android:background="@drawable/bg_price_tag"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Dual-thumb range slider -->
                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/priceRangeSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="5000000"
                    android:stepSize="50000"
                    app:thumbColor="#226CEB"
                    app:trackColorActive="#226CEB"
                    app:trackColorInactive="#D6E4FF"
                    app:haloColor="#4D226CEB"
                    app:labelBehavior="floating"
                    android:layout_marginStart="-4dp"
                    android:layout_marginEnd="-4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8ECF0" />

        <!-- Category chips section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_filter_genre"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1C1B1B"
                android:layout_marginBottom="12dp" />

            <!-- Row 1: Music + Arts + Workshop -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/chipCatMusic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_live_music"
                    android:textSize="13sp"
                    android:textColor="#1C1B1B"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipCatArts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_arts"
                    android:textSize="13sp"
                    android:textColor="#1C1B1B"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipCatWorkshop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_workshop"
                    android:textSize="13sp"
                    android:textColor="#1C1B1B"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Row 2: Tour + Sports + Festival -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipCatTour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_tour"
                    android:textSize="13sp"
                    android:textColor="#1C1B1B"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipCatSports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_sports"
                    android:textSize="13sp"
                    android:textColor="#1C1B1B"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipCatFestival"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_filter_festival"
                    android:textSize="13sp"
                    android:textColor="#1C1B1B"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8ECF0" />

        <!-- Button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/str_filter_reset"
                android:textColor="#226CEB"
                app:strokeColor="#226CEB" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterApply"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/str_filter_apply"
                android:textColor="#FFFFFF"
                app:backgroundTint="#226CEB" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

