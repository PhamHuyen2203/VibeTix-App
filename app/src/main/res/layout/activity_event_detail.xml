<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/clr_bg_light">

    <!-- Collapsing Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="280dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/clr_primary">

            <ImageView
                android:id="@+id/ivEventDetailPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_cat_music"
                app:layout_collapseMode="parallax" />

            <!-- Gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_banner_overlay"
                app:layout_collapseMode="parallax" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarEventDetail"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIconTint="@color/clr_text_white" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Main Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvEventDetailTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tên sự kiện"
                        android:textColor="@color/clr_text_black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Date/Time Row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_calendar_small"
                            android:tint="@color/clr_primary" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tvEventDetailDate"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/clr_text_black" android:textSize="14sp"
                            android:layout_marginEnd="16dp"/>
                        <TextView android:id="@+id/tvEventDetailTime"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/clr_text_secondary" android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Venue Row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_location_small"
                            android:tint="@color/clr_error" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tvEventDetailVenue"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Địa điểm" android:textColor="@color/clr_text_black" android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/clr_divider" android:layout_marginBottom="16dp"/>

                    <!-- Organizer Info -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ban tổ chức" android:textColor="@color/clr_text_secondary"
                        android:textSize="12sp" android:layout_marginBottom="6dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_organizer_placeholder"
                            android:background="@drawable/bg_avatar_circle"
                            android:layout_marginEnd="10dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tvOrganizerName"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ban tổ chức" android:textColor="@color/clr_text_black"
                                android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:id="@+id/tvOrganizerStatus"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Chưa xác minh" android:textColor="@color/clr_text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Description Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mô tả sự kiện" android:textColor="@color/clr_text_black"
                        android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvEventDetailDescription"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Chưa có mô tả" android:textColor="@color/clr_text_secondary"
                        android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ticket Types -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn loại vé"
                android:textColor="@color/clr_text_black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTicketTypes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buy Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBuyTicket"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎫  Mua vé ngay"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        app:cornerRadius="12dp" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>
