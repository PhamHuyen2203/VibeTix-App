<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Top Toolbar Header -->
    <LinearLayout
        android:id="@+id/layoutSelectHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="2dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnSelectBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@drawable/ic_back" 
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="Chọn vé"
                android:textColor="@color/clr_text_black"
                android:textSize="18sp" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Progress Step Indicator Bar -->
    <LinearLayout
        android:id="@+id/layoutSelectProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutSelectHeader">

        <!-- Step 1 (Active) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/clr_text_white"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn vé"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_divider" />

        <!-- Step 2 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thông tin"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_divider" />

        <!-- Step 3 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thanh toán"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_divider" />

        <!-- Step 4 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hoàn tất"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Booking Step -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/layoutSelectBottomBar"
        app:layout_constraintTop_toBottomOf="@+id/layoutSelectProgress">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Event Card Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imvSelectEventThumb"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/event_live_non_song"
                        app:cornerRadius="8dp" 
                        android:contentDescription="Ảnh sự kiện" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtSelectEventTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:text="LUNCH &amp; LEARN: Workshop về Phỏng vấn Ứng viên"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtSelectEventDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="09:00 - 12:00, 23 May, 2026"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtSelectEventLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="WB Business Center, Quận 3, TP. Hồ Chí Minh"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Seatmap Card (hidden by default, shown if seatmap_url exists) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSeatmap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Sơ đồ chỗ ngồi"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <ImageView
                        android:id="@+id/imvSeatmap"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="fitCenter" 
                        android:contentDescription="Sơ đồ chỗ ngồi của sự kiện" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ticket Types Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Chọn loại vé"
                        android:textColor="@color/clr_text_black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Dynamically populated by SelectTicketFragment -->
                    <LinearLayout
                        android:id="@+id/layoutTicketTypeRows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- Hidden legacy views (kept for backward compat, unused) -->
                    <TextView
                        android:id="@+id/txtSelectTicketTypeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/txtSelectTicketPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/txtSelectRemainingBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                    <android.widget.ImageButton
                        android:id="@+id/btnSelectQtyMinus"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />
                    <android.widget.ImageButton
                        android:id="@+id/btnSelectQtyPlus"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/txtSelectQtyValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Guidelines / Terms Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin vé ℹ"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="3dp"
                        android:text="• Vé điện tử sẽ được gửi đến email của bạn sau khi thanh toán thành công.\n• Vui lòng đến trước 15 phút để làm thủ tục check-in.\n• Vé đã mua không hoàn hủy. Vui lòng xem điều kiện chi tiết."
                        android:textColor="@color/clr_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Pricing / Navigation bar -->
    <LinearLayout
        android:id="@+id/layoutSelectBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Tiny info thumb -->
        <ImageView
            android:id="@+id/imvSelectBottomThumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:src="@drawable/event_live_non_song"
            app:cornerRadius="4dp" 
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtSelectBottomEventTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="LUNCH &amp; LEARN..."
                android:textColor="@color/clr_text_black"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSelectBottomQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_quick_chip"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="x1"
                android:textColor="@color/clr_primary_blue"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng cộng"
                android:textColor="@color/clr_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/txtSelectBottomTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="400.000 đ"
                android:textColor="@color/clr_primary_blue"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSelectNext"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="@color/clr_grey_1"
            android:enabled="false"
            android:fontFamily="sans-serif-medium"
            android:text="Vui lòng chọn vé"
            android:textColor="@color/clr_text_white"
            android:textSize="14sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
