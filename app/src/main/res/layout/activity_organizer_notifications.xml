<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/clr_bg_light">
    <LinearLayout android:layout_width="match_parent" android:layout_height="?attr/actionBarSize" android:background="@color/clr_bg_white" android:elevation="4dp" android:gravity="center_vertical" android:orientation="horizontal">
        <ImageView android:id="@+id/btnBack" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:padding="12dp" android:src="@drawable/ic_back" app:tint="@color/clr_text_black" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Trung tâm thông báo" android:textColor="@color/clr_text_black" android:textSize="18sp" android:textStyle="bold" />
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="Không có thông báo nào" android:gravity="center" android:textColor="@color/clr_text_secondary" />
</LinearLayout>
