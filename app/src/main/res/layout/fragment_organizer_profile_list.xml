<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light"
    android:orientation="vertical">

    <!-- ── HEADER — cùng style Toolbar như các trang client ────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_primary"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:elevation="4dp">

        <!-- Toolbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btnBackOrgProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_btn_back_circle"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/str_back"
                app:tint="@color/clr_text_white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_org_profile_list_title"
                    android:textColor="@color/clr_text_white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOrgCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    tools:text="3 hồ sơ ban tổ chức" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddOrgProfile"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/str_add_new_action"
                android:textAllCaps="false"
                android:textColor="@color/clr_text_white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:strokeColor="@color/clr_text_white"
                app:strokeWidth="1.5dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ── BODY ───────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="32dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/str_org_profile_list_title"
                    android:textColor="@color/clr_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/pbProfileLoading"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Organizer list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrganizerProfiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_organizer_profile_card" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/layoutOrgEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="48dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_role_building"
                    app:tint="@color/clr_grey_2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/str_no_org_profiles"
                    android:textColor="@color/clr_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Tạo hồ sơ đầu tiên để bắt đầu\nquản lý sự kiện của bạn"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Error -->
            <TextView
                android:id="@+id/tvProfileError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/clr_error"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Không thể tải thông tin. Thử lại." />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>

