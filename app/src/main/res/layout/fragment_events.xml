<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF9F8"
    android:orientation="vertical">

    <!-- ══ HEADER — tái sử dụng đúng header của trang chủ ══ -->
    <include
        android:id="@+id/eventsHeaderInclude"
        layout="@layout/include_home_header" />

    <!-- ══ CATEGORY CHIPS (horizontal scroll) ══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <LinearLayout
            android:id="@+id/containerCategoryChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp" />
    </HorizontalScrollView>

    <!-- ══ FILTER ROW ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <!-- Sort -->
        <LinearLayout
            android:id="@+id/btnFilterSort"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_filter"
                android:tint="#226CEB"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtFilterSort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Mới nhất"
                android:textColor="#226CEB"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="▾"
                android:textColor="#226CEB"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Location filter -->
        <LinearLayout
            android:id="@+id/btnFilterCity"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location_small"
                android:tint="#808E92"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtFilterCity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Tất cả tỉnh thành"
                android:textColor="#808E92"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="▾"
                android:textColor="#808E92"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" />

    <!-- ══ EVENTS GRID ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

</LinearLayout>
