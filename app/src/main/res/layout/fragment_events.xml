<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF9F8"
    android:orientation="vertical">

    <!-- ══ HEADER — tái sử dụng đúng header của trang chủ ══ -->
    <include
        android:id="@+id/eventsHeaderInclude"
        layout="@layout/include_home_header" />

    <!-- ══ CATEGORY CHIPS (horizontal scroll) ══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <LinearLayout
            android:id="@+id/containerCategoryChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp" />
    </HorizontalScrollView>

    <!-- ══ FILTER ROW ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <!-- Sort -->
        <LinearLayout
            android:id="@+id/btnFilterSort"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_filter"
                android:tint="#226CEB"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtFilterSort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Mới nhất"
                android:textColor="#226CEB"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="▾"
                android:textColor="#226CEB"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Location filter -->
        <LinearLayout
            android:id="@+id/btnFilterCity"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location_small"
                android:tint="#808E92"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtFilterCity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Tất cả tỉnh thành"
                android:textColor="#808E92"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="▾"
                android:textColor="#808E92"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" />

    <!-- ══ LOADING INDICATOR ══ -->
    <ProgressBar
        android:id="@+id/pbEventsLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="visible" />

    <!-- ══ ERROR / EMPTY STATE ══ -->
    <LinearLayout
        android:id="@+id/layoutErrorEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgErrorEmpty"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_search"
            android:tint="#A0AAB0"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/txtErrorEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Không tìm thấy sự kiện"
            android:textColor="#1C1B1B"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtErrorEmptySub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Vui lòng kiểm tra lại kết nối mạng hoặc thử lọc lại danh mục khác."
            android:textColor="#808E92"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnRetryEvents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_btn_primary"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="Thử lại"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ══ EVENTS GRID ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:visibility="gone" />

</LinearLayout>
