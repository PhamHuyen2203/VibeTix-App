<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtListingType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_resale_ticket_badge"
                android:textColor="@color/clr_text_black"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtListingBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_resale_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/str_resale_badge_caps"
                android:textColor="@color/clr_text_white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Seller note / message -->
        <TextView
            android:id="@+id/txtListingMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Vé chính chủ, sang nhượng do bận việc"
            android:textColor="@color/clr_text_secondary"
            android:textSize="13sp" />

        <!-- Seller + quantity row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtListingSeller"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Người bán: ****"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtListingQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số lượng: 1"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/clr_divider" />

        <!-- Price + buy button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_resale_price_label"
                    android:textColor="@color/clr_grey_1"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/txtListingPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="350,000 đ"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnListingBuy"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:backgroundTint="@color/clr_btn_blue"
                android:paddingHorizontal="24dp"
                android:text="@string/str_buy_resale_btn"
                android:textColor="@color/clr_text_white"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

