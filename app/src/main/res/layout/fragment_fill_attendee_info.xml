<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Top Toolbar Header -->
    <LinearLayout
        android:id="@+id/layoutInfoHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="2dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnInfoBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@drawable/ic_back" 
                android:contentDescription="@string/str_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_attendee_info_title"
                android:textColor="@color/clr_text_black"
                android:textSize="18sp" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Progress Step Indicator Bar -->
    <LinearLayout
        android:id="@+id/layoutInfoProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutInfoHeader">

        <!-- Step 1 (Completed — clickable to go back) -->
        <LinearLayout
            android:id="@+id/layoutInfoStep1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:padding="4dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/clr_text_white" 
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/ticket_select_title"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="32dp"
            android:layout_height="1dp"
            android:layout_marginBottom="14dp"
            android:background="@color/clr_primary_blue" />

        <!-- Step 2 (Active) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/clr_text_white"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_step_info"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="32dp"
            android:layout_height="1dp"
            android:layout_marginBottom="14dp"
            android:background="@color/clr_divider" />

        <!-- Step 3 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_step_payment"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="32dp"
            android:layout_height="1dp"
            android:layout_marginBottom="14dp"
            android:background="@color/clr_divider" />

        <!-- Step 4 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_step_done"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Attendee Form -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/layoutInfoBottomBar"
        app:layout_constraintTop_toBottomOf="@+id/layoutInfoProgress">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Event Card Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imvInfoEventThumb"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/event_live_non_song"
                        app:cornerRadius="8dp" 
                        android:contentDescription="@string/str_cd_event_image" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtInfoEventTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="2"
                            android:text="Tên sự kiện"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtInfoEventDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="--"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtInfoEventLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="--"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Attendee Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/str_attendee_info_title"
                        android:textColor="@color/clr_text_black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Họ và Tên (required) -->
                    <TextView
                        android:id="@+id/lblInfoName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <AutoCompleteTextView
                        android:id="@+id/etInfoName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:completionThreshold="0"
                        android:dropDownAnchor="@id/etInfoName"
                        android:hint="@string/str_hint_attendee_name"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <!-- Email (required) -->
                    <TextView
                        android:id="@+id/lblInfoEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <AutoCompleteTextView
                        android:id="@+id/etInfoEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:completionThreshold="0"
                        android:hint="@string/str_hint_attendee_email"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <!-- Số điện thoại (required) -->
                    <TextView
                        android:id="@+id/lblInfoPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <AutoCompleteTextView
                        android:id="@+id/etInfoPhone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:completionThreshold="0"
                        android:hint="@string/str_hint_phone_placeholder"
                        android:inputType="phone"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <!-- Ghi chú (optional — no label text change needed) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/str_notes_label"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etInfoNotes"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:gravity="top|start"
                        android:hint="@string/str_hint_special_request"
                        android:inputType="textMultiLine"
                        android:padding="12dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtInfoNotesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_note_char_count"
                        android:textColor="@color/clr_grey_1"
                        android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Marketing Question Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_referral_question"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipFb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="@string/str_referral_facebook"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipLi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="@string/str_referral_linkedin"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipWeb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="@string/str_referral_website"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipFriends"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="@string/str_referral_friends"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipOther"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="@string/str_referral_other"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bottom padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom pricing and checkout button -->
    <LinearLayout
        android:id="@+id/layoutInfoBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_total_payment_label"
                android:textColor="@color/clr_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtInfoBottomTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0 đ"
                android:textColor="@color/clr_primary_blue"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnInfoNext"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="@color/clr_btn_blue"
            android:fontFamily="sans-serif-medium"
            android:text="@string/str_continue"
            android:textColor="@color/clr_text_white"
            android:textSize="14sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


