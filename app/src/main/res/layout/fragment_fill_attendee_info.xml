<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Top Toolbar Header -->
    <RelativeLayout
        android:id="@+id/layoutInfoHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnInfoBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-medium"
            android:text="Thông tin"
            android:textColor="@color/clr_text_black"
            android:textSize="18sp" />
    </RelativeLayout>

    <!-- Progress Step Indicator Bar -->
    <LinearLayout
        android:id="@+id/layoutInfoProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutInfoHeader">

        <!-- Step 1 (Completed) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:padding="4dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/clr_text_white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn vé"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_primary_blue" />

        <!-- Step 2 (Active) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/clr_text_white"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thông tin"
                android:textColor="@color/clr_primary_blue"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_divider" />

        <!-- Step 3 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thanh toán"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="@color/clr_divider" />

        <!-- Step 4 (Inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/clr_grey_1"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hoàn tất"
                android:textColor="@color/clr_grey_1"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Attendee Form -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/layoutInfoBottomBar"
        app:layout_constraintTop_toBottomOf="@+id/layoutInfoProgress">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Event Card Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imvInfoEventThumb"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/event_live_non_song"
                        app:cornerRadius="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtInfoEventTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:text="LUNCH &amp; LEARN: Workshop về Phỏng vấn Ứng viên"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtInfoEventDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="09:00 - 12:00, 23 May, 2026"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtInfoEventLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="WB Business Center, Quận 3, TP. Hồ Chí Minh"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Information Card Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Thông tin người tham dự"
                        android:textColor="@color/clr_text_black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Họ và Tên -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Họ &amp; tên *"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etInfoName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:hint="Nhập họ và tên đầy đủ"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <!-- Email Công ty -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Email *"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etInfoEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:hint="Nhập email"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <!-- Số Điện Thoại -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Số điện thoại *"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etInfoPhone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:hint="Nhập số điện thoại"
                        android:inputType="phone"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp" />

                    <!-- Tên Công ty & Chức vụ row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tên công ty"
                                android:textColor="@color/clr_text_black"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etInfoCompany"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_normal"
                                android:hint="Nhập tên công ty"
                                android:inputType="text"
                                android:paddingHorizontal="12dp"
                                android:textColor="@color/clr_text_black"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chức vụ"
                                android:textColor="@color/clr_text_black"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etInfoRole"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_normal"
                                android:hint="Nhập chức vụ"
                                android:inputType="text"
                                android:paddingHorizontal="12dp"
                                android:textColor="@color/clr_text_black"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Ghi Chú Thêm -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ghi chú thêm (tùy chọn)"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etInfoNotes"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_normal"
                        android:gravity="top|start"
                        android:hint="Nhập ghi chú nếu có (ví dụ: yêu cầu xuất hóa đơn, ăn chay...)"
                        android:inputType="textMultiLine"
                        android:padding="12dp"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:text="0/300"
                        android:textColor="@color/clr_grey_1"
                        android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Marketing Question Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bạn biết đến sự kiện này qua kênh nào?"
                        android:textColor="@color/clr_text_black"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Flow of Chips (using Flex-like or standard Linear rows) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipFb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Facebook"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipLi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="LinkedIn"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipWeb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Website"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipFriends"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Bạn bè giới thiệu"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipOther"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quick_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Khác"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom pricing and checkout button -->
    <LinearLayout
        android:id="@+id/layoutInfoBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng thanh toán"
                android:textColor="@color/clr_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtInfoBottomTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="400.000 đ"
                android:textColor="@color/clr_primary_blue"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnInfoNext"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="@color/clr_btn_blue"
            android:fontFamily="sans-serif-medium"
            android:text="Tiếp tục ›"
            android:textColor="@color/clr_text_white"
            android:textSize="14sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
