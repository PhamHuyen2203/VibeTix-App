<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_brand_name"
                style="@style/OrganizerText.Heading04"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_black"
                tools:text="VibeTix Entertainment Group" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/grey_2"
                tools:ignore="ContentDescription" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_email"
                style="@style/OrganizerText.Body02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="8dp"
                android:textColor="@color/grey_1"
                app:drawableStartCompat="@android:drawable/ic_dialog_email"
                app:drawableTint="@color/grey_1"
                tools:text="contact@vibetix.com" />

            <TextView
                android:id="@+id/tv_phone"
                style="@style/OrganizerText.Body02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="8dp"
                android:textColor="@color/grey_1"
                app:drawableStartCompat="@android:drawable/ic_menu_call"
                app:drawableTint="@color/grey_1"
                tools:text="0987 654 321" />

            <TextView
                android:id="@+id/tv_website"
                style="@style/OrganizerText.Body02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="8dp"
                android:textColor="@color/state_info"
                app:drawableStartCompat="@android:drawable/ic_menu_share"
                app:drawableTint="@color/state_info"
                tools:text="www.vibetix.group" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="@color/grey_2" />

        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reject"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:paddingHorizontal="16dp"
                android:text="@string/btn_reject"
                android:textAllCaps="false"
                android:textColor="@color/brand_red"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconTint="@color/brand_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_approve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/brand_green"
                android:paddingHorizontal="24dp"
                android:text="@string/btn_approve"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/checkbox_on_background"
                app:iconTint="@color/white" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
