<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/clr_bg_white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:rippleColor="#1A2563EB"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top section: logo + info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="14dp">

            <!-- Logo with optional ring -->
            <FrameLayout
                android:layout_width="58dp"
                android:layout_height="58dp">

                <ImageView
                    android:id="@+id/ivOrgLogo"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_role_building" />
            </FrameLayout>

            <!-- Info column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOrgBrandName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/clr_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="VibeTix Events" />

                <TextView
                    android:id="@+id/tvVerifiedChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="3dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="● Đã xác thực" />

                <TextView
                    android:id="@+id/tvOrgDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="12sp"
                    tools:text="Đơn vị tổ chức sự kiện hàng đầu" />

                <TextView
                    android:id="@+id/tvOrgWebsiteSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:text="vibetix.vn" />
            </LinearLayout>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right"
                android:tint="#C8CBD0" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/clr_divider" />

        <!-- Stats footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatEvents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Sự kiện"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:background="@color/clr_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatTickets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/clr_primary_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="248" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Vé bán"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:background="@color/clr_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/clr_success"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="5.5Mđ" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Doanh thu"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action buttons: Edit + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditOrg"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:text="Chỉnh sửa"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/clr_primary_blue"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteOrg"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:text="Xóa"
                android:textAllCaps="false"
                android:textColor="@color/clr_error"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/clr_error"
                app:strokeWidth="1.5dp" />
        </LinearLayout>

        <!-- Accent bar (bottom) -->
        <View
            android:id="@+id/viewAccentBar"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/clr_primary_blue" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
