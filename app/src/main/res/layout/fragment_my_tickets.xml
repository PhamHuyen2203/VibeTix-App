<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/clr_bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_primary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="0dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vé của tôi"
            android:textColor="@color/clr_text_white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabMyTickets"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:tabTextColor="#80FFFFFF"
            app:tabSelectedTextColor="@color/clr_text_white"
            app:tabIndicatorColor="@color/clr_text_white"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            android:background="@null">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sắp diễn ra" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã xem" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã huỷ" />

        </com.google.android.material.tabs.TabLayout>
    </LinearLayout>

    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshTickets"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyTickets"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmptyTickets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🎫" android:textSize="64sp" android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvEmptyTicketMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn chưa có vé nào\nHãy khám phá sự kiện!"
                android:textSize="16sp"
                android:textColor="@color/clr_text_secondary"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Khám phá sự kiện"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                app:cornerRadius="24dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
