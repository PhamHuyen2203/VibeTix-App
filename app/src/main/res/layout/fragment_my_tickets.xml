<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Top Dashboard Header -->
    <LinearLayout
        android:id="@+id/layoutMyTicketsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="Vé của tôi  ✨"
                android:textColor="@color/clr_text_black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- VibeTix App Icon in Header -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnHeaderAppIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/app_icon" 
                    android:importantForAccessibility="no" />
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <!-- Category Horizontal Outlined pill tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="12dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tabCategoryBought"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tab_active_outline"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="Vé đã mua"
                android:textColor="@color/clr_primary_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabCategoryReselling"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_filter"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="Vé bán lại"
                android:textColor="@color/clr_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Dynamic Sub-Tabs Frame Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Sub-Tabs Row for "Vé đã mua" (Sắp diễn ra | Đã kết thúc) -->
            <LinearLayout
                android:id="@+id/layoutSubTabsBought"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="visible">

                <LinearLayout
                    android:id="@+id/tabSubUpcoming"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtSubUpcoming"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:text="Sắp diễn ra"
                        android:textColor="@color/clr_primary_blue"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <View
                        android:id="@+id/indicatorSubUpcoming"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/clr_primary_blue" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabSubEnded"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtSubEnded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:text="Đã kết thúc"
                        android:textColor="@color/clr_text_secondary"
                        android:textSize="13sp" />
                    <View
                        android:id="@+id/indicatorSubEnded"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@android:color/transparent" />
                </LinearLayout>
            </LinearLayout>

            <!-- Sub-Tabs Row for "Vé bán lại" — 6 tabs, horizontally scrollable -->
            <HorizontalScrollView
                android:id="@+id/layoutSubTabsResale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Đang rao bán -->
                    <LinearLayout
                        android:id="@+id/tabResalePending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:id="@+id/txtResalePending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="Đang rao bán"
                            android:textColor="@color/clr_primary_blue"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <View
                            android:id="@+id/indicatorResalePending"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@color/clr_primary_blue" />
                    </LinearLayout>

                    <!-- Đã có người mua -->
                    <LinearLayout
                        android:id="@+id/tabResaleActive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:id="@+id/txtResaleActive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="Chờ thanh toán"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <View
                            android:id="@+id/indicatorResaleActive"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>

                    <!-- Đã bán -->
                    <LinearLayout
                        android:id="@+id/tabResaleSold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:id="@+id/txtResaleSold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="Đã bán"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <View
                            android:id="@+id/indicatorResaleSold"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>

                    <!-- Đã hủy -->
                    <LinearLayout
                        android:id="@+id/tabResaleCancelled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:id="@+id/txtResaleCancelled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="Đã hủy"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <View
                            android:id="@+id/indicatorResaleCancelled"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>

                    <!-- Bị từ chối -->
                    <LinearLayout
                        android:id="@+id/tabResaleRejected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:id="@+id/txtResaleRejected"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="Bị từ chối"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <View
                            android:id="@+id/indicatorResaleRejected"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>

                    <!-- Hết hạn -->
                    <LinearLayout
                        android:id="@+id/tabResaleExpired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:id="@+id/txtResaleExpired"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10dp"
                            android:text="Hết hạn"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp" />
                        <View
                            android:id="@+id/indicatorResaleExpired"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </FrameLayout>
    </LinearLayout>

    <!-- Resale pricing/info bar + Filter (visible under "Vé bán lại" tab) -->
    <RelativeLayout
        android:id="@+id/layoutResaleInfoRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_light"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/layoutMyTicketsHeader">

        <!-- Tổng thực nhận label -->
        <TextView
            android:id="@+id/txtResaleEarningsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-medium"
            android:text="Tổng thực nhận: 0 đ"
            android:textColor="@color/clr_text_black"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Blue outlined filter icon button with red dot -->
        <FrameLayout
            android:id="@+id/btnResaleFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <androidx.cardview.widget.CardView
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/clr_bg_white">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/clr_primary_blue" 
                    android:importantForAccessibility="no" />
            </androidx.cardview.widget.CardView>

            <!-- Red Notification Dot -->
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_auth_header"
                android:backgroundTint="@color/clr_red" />
        </FrameLayout>
    </RelativeLayout>

    <!-- Main Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutResaleInfoRow"
        tools:layout_editor_absoluteX="0dp">

        <!-- RecyclerView for ticket listings -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMyTicketsList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp"
            android:visibility="gone" />

        <!-- Empty State Container -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layoutMyTicketsEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Cartoon Illustration Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/clr_bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="32dp">

                        <ImageView
                            android:id="@+id/imvEmptyStateMascot"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:src="@drawable/img_vibetix_mascot" 
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/txtEmptyStateTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Bạn chưa có vé nào cả!"
                            android:textColor="@color/clr_text_black"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/txtEmptyStateSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Khám phá sự kiện và đặt vé cho những trải nghiệm đáng nhớ đang chờ bạn."
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="12sp" />

                        <!-- Dynamic action button (can be buy now or resell tickets based on category tab) -->
                        <Button
                            android:id="@+id/btnEmptyStateAction"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/bg_btn_gradient"
                            android:backgroundTint="@null"
                            android:fontFamily="sans-serif-medium"
                            android:text="🎟  Mua vé ngay"
                            android:textColor="@color/clr_text_white"
                            app:cornerRadius="24dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Recommendation header (visible under empty bought tab) -->
                <RelativeLayout
                    android:id="@+id/layoutEmptyRecommendationsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Có thể bạn cũng thích"
                        android:textColor="@color/clr_text_black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtEmptyRecommendationsSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Xem tất cả ›"
                        android:textColor="@color/clr_primary_blue"
                        android:textSize="13sp" />
                </RelativeLayout>

                <!-- Horizontal suggestions RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEmptyRecommendationsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>