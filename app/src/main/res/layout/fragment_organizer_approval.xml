<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout_organizer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/clr_bg_white"
            app:tabIndicatorColor="@color/clr_primary_blue"
            app:tabSelectedTextColor="@color/clr_primary_blue"
            app:tabTextColor="@color/clr_grey_1">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_pending" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_verified" />

        </com.google.android.material.tabs.TabLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_organizers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:paddingTop="8dp" />

    </LinearLayout>

    <include
        android:id="@+id/layout_empty"
        layout="@layout/fragment_empty_state"
        android:visibility="gone" />

</FrameLayout>
