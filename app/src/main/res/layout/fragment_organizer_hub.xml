<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- ════════════════════════════════════════════════════ -->
    <!-- LOADING STATE -->
    <ProgressBar
        android:id="@+id/pbLoadingHub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible" />

    <!-- STATE A: Chưa là Organizer                          -->
    <!-- ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutBecomeOrganizer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:visibility="gone">

        <!-- Gradient header — đồng nhất brand -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_organizer_header"
            android:fitsSystemWindows="true"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_org_hub_title"
                android:textColor="@color/clr_text_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:alpha="0.92" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_org_hub_subtitle"
                android:textColor="@color/clr_text_white"
                android:textSize="13sp"
                android:alpha="0.80"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <ImageView
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/ic_nav_my_events"
                    app:tint="@color/clr_primary"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_org_hub_welcome"
                    android:textColor="@color/clr_text_black"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str_org_hub_desc"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="28dp" />

                <!-- Benefits card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@drawable/ic_calendar_small" app:tint="@color/clr_primary" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:layout_marginStart="16dp" android:text="@string/str_org_benefit_1"
                                android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@drawable/ic_nav_ticket" app:tint="@color/clr_primary" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:layout_marginStart="16dp" android:text="@string/str_org_benefit_2"
                                android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@drawable/ic_nav_dashboard" app:tint="@color/clr_primary" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:layout_marginStart="16dp" android:text="@string/str_org_benefit_3"
                                android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@drawable/ic_search" app:tint="@color/clr_primary" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:layout_marginStart="16dp" android:text="@string/str_org_benefit_4"
                                android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateFirstEvent"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/str_org_create_first_event"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/clr_primary" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- STATE B: Đã là Organizer — Dashboard                -->
    <!-- ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutOrganizerDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Container for the Dashboard fragment -->
        <FrameLayout
            android:id="@+id/frameOrganizerHubContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</FrameLayout>

