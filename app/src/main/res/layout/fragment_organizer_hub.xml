<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- ════════════════════════════════════════════════════ -->
    <!-- STATE A: Chưa là Organizer                          -->
    <!-- ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutBecomeOrganizer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:src="@drawable/ic_nav_my_events"
                    android:tint="@color/clr_primary"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào mừng Organizer!"
                    android:textColor="@color/clr_text_black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bắt đầu hành trình tổ chức sự kiện và quản lý bán vé chuyên nghiệp cùng VibeTix."
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="32dp" />

                <!-- Benefits -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded_white"
                    android:padding="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="32dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar_small" android:tint="@color/clr_primary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:layout_marginStart="16dp" android:text="Tạo và quản lý sự kiện dễ dàng"
                            android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_ticket" android:tint="@color/clr_primary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:layout_marginStart="16dp" android:text="Bán vé trực tuyến, thanh toán tự động"
                            android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_dashboard" android:tint="@color/clr_primary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:layout_marginStart="16dp" android:text="Theo dõi doanh thu thời gian thực"
                            android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_search" android:tint="@color/clr_primary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:layout_marginStart="16dp" android:text="Quét mã QR check-in nhanh chóng"
                            android:textColor="@color/clr_text_black" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateFirstEvent"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🚀  Tạo Sự Kiện Đầu Tiên"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/clr_primary" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- STATE B: Đã là Organizer — Dashboard                -->
    <!-- ════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layoutOrganizerDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header với Organizer Selector ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/clr_primary"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="52dp"
                android:paddingBottom="20dp">

                <ImageView
                    android:id="@+id/ivOrgLogo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_organizer_placeholder"
                    android:background="@drawable/bg_circle_white_alpha"
                    android:scaleType="centerCrop"
                    android:padding="2dp" />

                <LinearLayout
                    android:id="@+id/btnSwitchOrganizer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvOrgName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ban tổ chức"
                            android:textColor="@color/clr_text_white"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_chevron_down"
                            android:tint="@color/clr_text_white" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvOrgSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ban tổ chức của bạn"
                        android:textColor="#CCE0F7"
                        android:textSize="12sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_bell"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/clr_text_white" />

            </LinearLayout>

            <!-- ── Stats Cards ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginTop="-1dp">

                <!-- Revenue -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp" android:background="@color/clr_bg_white">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰" android:textSize="20sp" android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvStatRevenue" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0đ"
                            android:textColor="@color/clr_primary" android:textSize="14sp" android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Doanh thu" android:textColor="@color/clr_text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tickets -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp" android:background="@color/clr_bg_white">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎫" android:textSize="20sp" android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvStatTickets" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="@color/clr_success" android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Vé đã bán" android:textColor="@color/clr_text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Check-ins -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp" android:background="@color/clr_bg_white">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✅" android:textSize="20sp" android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvStatCheckins" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="@color/clr_warning" android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Check-in HN" android:textColor="@color/clr_text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Quick Actions Grid ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thao tác nhanh"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/clr_text_black"
                android:paddingStart="20dp"
                android:paddingBottom="12dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp">

                <include layout="@layout/item_quick_action"
                    android:id="@+id/actionMyEvents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include layout="@layout/item_quick_action"
                    android:id="@+id/actionCreateEvent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include layout="@layout/item_quick_action"
                    android:id="@+id/actionRevenue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include layout="@layout/item_quick_action"
                    android:id="@+id/actionStaff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include layout="@layout/item_quick_action"
                    android:id="@+id/actionTicketTypes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include layout="@layout/item_quick_action"
                    android:id="@+id/actionNotification"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

            </GridLayout>

            <!-- ── Recent Events ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sự kiện gần đây"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/clr_text_black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả ›"
                    android:textColor="@color/clr_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
