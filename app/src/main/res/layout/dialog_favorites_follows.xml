<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minHeight="500dp"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/clr_bg_white">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_search_bar" />

    <!-- Title (dynamic theo mode) -->
    <TextView
        android:id="@+id/txtSheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/str_favorites"
        android:textColor="@color/clr_text_black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Section: Favorite Events -->
    <TextView
        android:id="@+id/txtHeaderFavorites"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/str_suggestions_for_you"
        android:textColor="#808E92"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFavoriteEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <TextView
        android:id="@+id/txtNoFavorites"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/str_no_data"
        android:textColor="#B0B8C1"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#EEF0F5" />

    <!-- Section: Following Stars/Organizers -->
    <TextView
        android:id="@+id/txtHeaderFollowing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/str_following"
        android:textColor="#808E92"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFollowing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <TextView
        android:id="@+id/txtNoFollowing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/str_no_data"
        android:textColor="#B0B8C1"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Bottom spacing -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

</LinearLayout>

