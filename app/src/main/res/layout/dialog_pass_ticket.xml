<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Bán lại vé (Pass vé) 🎫"
            android:textColor="@color/clr_text_black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Explanatory note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"
            android:text="Đăng bán vé của bạn lên sàn giao dịch VibeTix. Người mua sẽ nhận được vé mới và tiền sẽ được chuyển vào tài khoản của bạn sau khi giao dịch thành công."
            android:textColor="@color/clr_text_secondary"
            android:textSize="13sp" />

        <!-- Ticket Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/clr_bg_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPassDialogEventTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="LUNCH &amp; LEARN: Workshop về Phỏng vấn Ứng viên"
                    android:textColor="@color/clr_text_black"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtPassDialogOriginalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_quick_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="Giá mua gốc: 400.000 đ"
                    android:textColor="@color/clr_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Type selector — only shown when card has multiple distinct ticket types (B2) -->
        <LinearLayout
            android:id="@+id/layoutTypeSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chọn loại vé muốn bán *"
                android:textColor="@color/clr_text_black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/containerTypeRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Giá bán được đặt theo từng loại vé trong type selector phía trên -->

        <!-- Message block (optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Lời nhắn cho người mua (tuỳ chọn)"
            android:textColor="@color/clr_text_black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPassMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_normal"
            android:gravity="top"
            android:hint="Ví dụ: Vé chính chủ, sang nhượng do bận việc..."
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:padding="16dp"
            android:textColor="@color/clr_text_black"
            android:textSize="14sp" />

        <!-- Actions block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPassCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Để sau"
                android:textColor="@color/clr_grey_1" />

            <Button
                android:id="@+id/btnPassConfirm"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.5"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/clr_btn_blue"
                android:fontFamily="sans-serif-medium"
                android:text="Xác nhận đăng bán"
                android:textColor="@color/clr_text_white"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
