<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_page">

    <!-- AppBar with Parallax Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarEventHub"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/clr_primary"
            app:titleEnabled="false">

            <!-- Event Poster as Full Background -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivHubEventPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6"
                android:src="@drawable/ic_organizer_placeholder" />

            <!-- Dark Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_banner_overlay"
                app:layout_collapseMode="parallax" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarEventHub"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:titleTextColor="@color/clr_text_on_primary"
                app:navigationIconTint="@color/clr_text_on_primary" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ OVERLAPPING EVENT INFO CARD ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-60dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/clr_bg_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Badges row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvHubRoleBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👑 OWNER"
                            android:textSize="10sp"
                            android:textColor="@color/clr_text_on_primary"
                            android:textStyle="bold"
                            android:background="@drawable/bg_role_owner"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp" />

                        <TextView
                            android:id="@+id/tvHubStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="● APPROVED"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/clr_success" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvHubEventTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/clr_text_primary"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingExtra="2dp"
                        android:text="Tên sự kiện" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <!-- Date -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/ic_calendar_small"
                                app:tint="@color/clr_text_secondary" />
                            <TextView
                                android:id="@+id/tvHubEventDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textSize="13sp"
                                android:textColor="@color/clr_text_secondary" />
                        </LinearLayout>

                        <!-- Venue -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/ic_location_small"
                                app:tint="@color/clr_text_secondary" />
                            <TextView
                                android:id="@+id/tvHubEventVenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textSize="13sp"
                                android:textColor="@color/clr_text_secondary"
                                android:maxLines="2"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ STATS DASHBOARD — Ẩn với check_in_staff ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutHubStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/clr_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Label nhỏ -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOANH THU SỰ KIỆN"
                        android:textColor="#A8C4F8"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />

                    <!-- Doanh thu — TO NHẤT, nổi bật nhất -->
                    <TextView
                        android:id="@+id/tvHubStatRevenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="0 ₫"
                        android:textColor="@color/clr_text_on_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="16sp"
                        app:autoSizeMaxTextSize="30sp"
                        app:autoSizeStepGranularity="1sp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF" />

                    <!-- Hai chỉ số phụ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical">

                        <!-- Vé đã bán -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VÉ ĐÃ BÁN"
                                android:textColor="#A8C4F8"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvHubStatTickets"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                android:textColor="@color/clr_text_on_primary"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Separator dọc -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="44dp"
                            android:layout_marginHorizontal="20dp"
                            android:background="#33FFFFFF" />

                        <!-- Check-in hôm nay -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CHECK-IN HÔM NAY"
                                android:textColor="#A8C4F8"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvHubStatCheckins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                android:textColor="#69FF97"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ FEATURE GRID SECTION HEADER ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="10dp"
                android:text="TÍNH NĂNG QUẢN LÝ"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/clr_text_secondary"
                android:letterSpacing="0.1" />

            <!-- ═══ FEATURE GRID — RecyclerView với GridLayoutManager 2 cột ═══ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHubFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingBottom="32dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
