<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/destination_card_width"
    android:layout_height="@dimen/destination_card_height"
    android:layout_marginEnd="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="2dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imvDestinationImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/str_cd_event_image"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_banner_overlay" />

        <TextView
            android:id="@+id/txtDestinationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:padding="@dimen/spacing_xs"
            android:text="Hà Nội"
            android:textColor="@color/clr_text_white"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold" />
    </FrameLayout>

</androidx.cardview.widget.CardView>
