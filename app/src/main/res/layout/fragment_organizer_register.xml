<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout dùng làm view bên trong AlertDialog (không cần header riêng,
    AlertDialog đã có title "Thông tin Ban tổ chức").
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <!-- Tên ban tổ chức -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_hint_organizer_brand_name"
            android:textColor="#1C1B1B"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtBrandName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_normal"
            android:hint="@string/str_hint_org_name"
            android:inputType="textCapWords"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#1C1B1B"
            android:textColorHint="#B0B8BC"
            android:textSize="14sp" />

        <!-- Mô tả ban tổ chức -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_hint_organizer_bio"
            android:textColor="#1C1B1B"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_normal"
            android:hint="@string/str_hint_org_name"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textColor="#1C1B1B"
            android:textColorHint="#B0B8BC"
            android:textSize="14sp" />

        <!-- Website -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_hint_organizer_website_optional"
            android:textColor="#1C1B1B"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtWebsite"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_normal"
            android:hint="@string/org_profile_website"
            android:inputType="textWebEmailAddress"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#1C1B1B"
            android:textColorHint="#B0B8BC"
            android:textSize="14sp" />

        <!-- Ghi chú quy trình -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_organizer_cta"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/ic_org_star"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_no_data"
                    android:textColor="#226CEB"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/str_organizer_review_notice"
                    android:textColor="#226CEB"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>


