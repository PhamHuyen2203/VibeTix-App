<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light"
    android:orientation="vertical">

    <!-- ═══ GRADIENT BLUE HEADER ═══ -->
    <LinearLayout
        android:id="@+id/layoutOrgHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_auth_header"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="20dp">

        <!-- Row: Avatar + Info + Edit button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Avatar circle (80dp) -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <ImageView
                    android:id="@+id/ivOrgAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="@null"
                    android:padding="18dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_role_building"
                    android:tint="@color/clr_primary_blue" />
            </FrameLayout>

            <!-- Brand Name + Badge -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOrgBrandName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/clr_text_white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Công ty Sự kiện ABC" />

                <!-- Verified / Pending badge -->
                <LinearLayout
                    android:id="@+id/layoutVerifiedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_verified_badge"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp">

                    <TextView
                        android:id="@+id/tvVerifiedBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/org_profile_verified"
                        android:textColor="@color/clr_success"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Edit Profile button (outlined white) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:text="@string/str_edit_profile"
                android:textAllCaps="false"
                android:textColor="@color/clr_text_white"
                android:textSize="12sp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/clr_text_white"
                app:strokeWidth="1.5dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ═══ SCROLLABLE BODY ═══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- ── STATS ROW: 3 white cards ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <!-- Card: Total Events -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/clr_bg_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvTotalEvents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/clr_primary_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="12" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/str_events_count_label"
                            android:textColor="@color/clr_grey_1"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Total Tickets -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="3dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/clr_bg_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎟️"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvTotalTicketsSold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/clr_primary_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="2.4K" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/str_tickets_sold_label"
                            android:textColor="@color/clr_grey_1"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Total Revenue -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/clr_bg_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvMonthlyRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/clr_primary_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="50M" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/str_revenue_label"
                            android:textColor="@color/clr_grey_1"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── INFO CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="@string/str_contact_info_title"
                        android:textColor="@color/clr_text_black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:gravity="center"
                            android:text="📧"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_email_contact"
                                android:textColor="@color/clr_grey_1"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvOrgEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/clr_text_black"
                                android:textSize="14sp"
                                tools:text="abc.events@gmail.com" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Phone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:gravity="center"
                            android:text="📞"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_phone_contact"
                                android:textColor="@color/clr_grey_1"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvOrgPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/clr_text_black"
                                android:textSize="14sp"
                                tools:text="0901 234 567" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Website -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:gravity="center"
                            android:text="🌐"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_website_contact"
                                android:textColor="@color/clr_grey_1"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvOrgWebsite"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/clr_primary_blue"
                                android:textSize="14sp"
                                tools:text="www.abcevents.vn" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── MULTI-ORG SECTION ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/str_org_profile_section_title"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/pbProfileLoading"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Organizer profiles RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvOrganizerProfiles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="2"
                        tools:listitem="@layout/item_organizer_switcher" />

                    <!-- Add org button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddOrgProfile"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:text="@string/str_add_new_profile"
                        android:textAllCaps="false"
                        android:textColor="@color/clr_primary_blue"
                        android:textSize="14sp"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/clr_primary_blue"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SETTINGS SECTION ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/str_settings_section_title"
                        android:textColor="@color/clr_grey_1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Notification settings -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:text="🔔"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/str_notification_settings"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            android:tint="@color/clr_grey_1" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@color/clr_divider" />

                    <!-- Payment info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:text="🏦"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/str_payment_info"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            android:tint="@color/clr_grey_1" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@color/clr_divider" />

                    <!-- Change password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:text="🔒"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/str_change_password_action"
                            android:textColor="@color/clr_text_black"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            android:tint="@color/clr_grey_1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Error text -->
            <TextView
                android:id="@+id/tvProfileError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/clr_error"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Không thể tải thông tin. Thử lại." />

            <!-- ── LOGOUT BUTTON ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrgLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:stateListAnimator="@null"
                android:text="@string/str_logout"
                android:textAllCaps="false"
                android:textColor="@color/clr_error"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/clr_bg_white"
                app:cornerRadius="12dp"
                app:strokeColor="@color/clr_error"
                app:strokeWidth="1.5dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>

