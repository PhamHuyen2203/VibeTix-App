<?xml version="1.0" encoding="utf-8"?>
<!-- item_feature_card.xml — Thẻ chức năng trong EventHub -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/clr_white"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivFeatureIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/tvFeatureName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/clr_text_black"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvFeatureNoPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/str_no_data"
            android:textSize="9sp"
            android:textColor="@color/clr_grey_1"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

