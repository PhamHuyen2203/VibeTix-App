<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light">

    <!-- Header Gradient Background -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_dashboard_header_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mascot Image for decoration -->
    <ImageView
        android:id="@+id/imgMascot"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/img_mascot_celebrate"
        android:alpha="0.2"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="-20dp"/>

    <!-- Toolbar Area -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/clr_text_on_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Báo cáo &amp; Phân tích"
            android:textColor="@color/clr_text_on_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Title Header inside ScrollView -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng quan hiệu suất"
                android:textColor="@color/clr_text_white"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp"/>

            <!-- Summary Cards Row (Overlapping) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:baselineAligned="false"
                android:layout_marginBottom="24dp">

                <!-- Revenue Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/clr_bg_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_trending_up"
                            app:tint="@color/clr_primary"
                            android:background="@drawable/bg_circle_white_alpha"
                            android:backgroundTint="#1A1A73E8"
                            android:padding="6dp"
                            android:layout_marginBottom="12dp"/>
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng doanh thu"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvTotalRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 ₫"
                            android:textColor="@color/clr_text_black"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tickets Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/clr_bg_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_ticket"
                            app:tint="#F2994A"
                            android:background="@drawable/bg_circle_white_alpha"
                            android:backgroundTint="#1AF2994A"
                            android:padding="6dp"
                            android:layout_marginBottom="12dp"/>
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vé bán / Check-in"
                            android:textColor="@color/clr_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvTotalTickets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 0"
                            android:textColor="@color/clr_text_black"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Chart Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tăng trưởng doanh thu"
                android:textColor="@color/clr_text_black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/clr_bg_white"
                android:layout_marginBottom="32dp">
                
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:layout_margin="16dp" />
            </androidx.cardview.widget.CardView>

            <!-- Export Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportCSV"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Xuất báo cáo Check-in (CSV)"
                android:textSize="16sp"
                app:icon="@drawable/ic_nav_ticket"
                app:iconGravity="textStart"
                android:textStyle="bold"
                app:backgroundTint="@color/clr_primary"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Loading -->
    <FrameLayout
        android:id="@+id/pbLoading"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <ProgressBar
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/clr_primary"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
