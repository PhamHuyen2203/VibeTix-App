<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/clr_bg_light">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarTicketType"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/clr_primary"
        app:titleTextColor="@color/clr_text_white"
        app:title="Quản lý Loại Vé" />

    <FrameLayout
        android:id="@+id/containerTicketType"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
