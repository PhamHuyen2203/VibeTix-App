<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/frameContainerMain"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/clr_divider" />

    <!--
        CUSTOM BOTTOM NAV — 5 items trong cùng 1 LinearLayout ngang.
        fitsSystemWindows=true để tự padding navigation bar (gesture bar).
        Tất cả 5 item có cùng structure: icon (24dp) + text (10sp).
        Item giữa dùng nút tròn xanh nổi bật thay icon.
    -->
    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_bg_white"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Tab 1: Trang chủ -->
        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/clr_primary_blue"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Trang chủ"
                android:textColor="@color/clr_primary_blue"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tab 2: Sự kiện -->
        <LinearLayout
            android:id="@+id/tabEvents"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icEvents"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_events"
                android:tint="#808E92"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtEvents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Sự kiện"
                android:textColor="#808E92"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Tab 3: Tạo sự kiện — nút tròn xanh nổi bật -->
        <LinearLayout
            android:id="@+id/tabCreate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <!-- marginTop âm = -(circle_height - icon_height) = -(40-24) = -16dp
                 Kéo nút tròn lên trên để text "Tạo sự kiện" thẳng hàng với 4 tab kia -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="-16dp"
                android:background="@drawable/bg_create_btn"
                android:elevation="4dp">

                <ImageView
                    android:id="@+id/fabCreateEvent"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_add_white"
                    android:contentDescription="Tạo sự kiện" />
            </FrameLayout>

            <TextView
                android:id="@+id/txtCreate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Tạo sự kiện"
                android:textColor="#808E92"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Tab 4: Vé của tôi -->
        <LinearLayout
            android:id="@+id/tabTickets"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icTickets"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_ticket"
                android:tint="#808E92"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtTickets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Vé của tôi"
                android:textColor="#808E92"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Tab 5: Cá nhân -->
        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_profile"
                android:tint="#808E92"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Cá nhân"
                android:textColor="#808E92"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

    <!--
        NÚT MIC TRỢ LÝ ACCESSIBILITY — nổi trên mọi màn hình của UserMainActivity.
        Người khiếm thị bấm để nói lệnh: tìm sự kiện, đọc chi tiết, đặt vé...
    -->
    <ImageButton
        android:id="@+id/btnAssistantMic"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:background="@drawable/bg_assistant_mic"
        android:src="@drawable/ic_mic"
        android:scaleType="centerInside"
        android:elevation="8dp"
        android:contentDescription="Trợ lý giọng nói. Nhấn để nói lệnh" />

</FrameLayout>
