<?xml version="1.0" encoding="utf-8"?>
<!--
  Organizer Events Fragment — Danh sách sự kiện của organizer
  Design: header xanh + search + ChipGroup filter + RecyclerView + FAB
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clr_bg_light"
    android:orientation="vertical">

    <!-- ═══ BLUE HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/clr_primary"
        android:elevation="4dp"
        android:orientation="vertical">

        <!-- Top bar: Logo + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="4dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/str_cd_app_logo"
                android:scaleType="fitStart"
                android:src="@drawable/ic_vibetix_logo_full" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_nav_org_events"
                android:textColor="@color/clr_text_white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            android:text="Sự kiện của tôi"
            android:textColor="@color/clr_text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="@color/clr_grey_1"
                android:contentDescription="@string/str_cd_search" />

            <EditText
                android:id="@+id/etEventSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/org_events_search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/clr_text_black"
                android:textColorHint="@color/clr_grey_1"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ STATUS FILTER CHIPS ═══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Tất cả"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDraft"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nháp"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPending"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ duyệt"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipApproved"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã duyệt"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOngoing"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang diễn"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCompleted"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoàn thành"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCancelled"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã huỷ"
                android:textSize="12sp" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- ═══ EVENTS LIST ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/pbEventsLoading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrganizerEvents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="80dp"
            android:nestedScrollingEnabled="true"
            tools:listitem="@layout/item_event_organizer_card" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEventsEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="64sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Chưa có sự kiện nào"
                android:textColor="@color/clr_text_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Tạo sự kiện đầu tiên để bắt đầu"
                android:textColor="@color/clr_grey_1"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateFirstEvent"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:stateListAnimator="@null"
                android:text="Tạo sự kiện"
                android:textAllCaps="false"
                android:textColor="@color/clr_text_white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/clr_primary"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconSize="18dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- ═══ FAB: Create Event ═══ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabCreateEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Tạo sự kiện"
        android:textAllCaps="false"
        android:textColor="@color/clr_text_white"
        android:textSize="14sp"
        app:backgroundTint="@color/clr_primary"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/clr_text_white" />

</LinearLayout>
