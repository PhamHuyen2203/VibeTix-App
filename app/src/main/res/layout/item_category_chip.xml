<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/category_chip_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_sm"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/imvCategoryIcon"
        android:layout_width="@dimen/category_icon_size"
        android:layout_height="@dimen/category_icon_size"
        android:background="@drawable/bg_category_icon"
        android:contentDescription="@null"
        android:padding="@dimen/spacing_sm"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/txtCategoryName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center"
        android:maxLines="2"
        android:text="Category"
        android:textColor="@color/clr_text_black"
        android:textSize="@dimen/text_xs" />

</LinearLayout>
