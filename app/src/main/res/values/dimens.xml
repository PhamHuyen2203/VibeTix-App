<resources>
    <!-- Spacing -->
    <dimen name="spacing_xs">4dp</dimen>
    <dimen name="spacing_sm">8dp</dimen>
    <dimen name="spacing_md">12dp</dimen>
    <dimen name="spacing_base">16dp</dimen>
    <dimen name="spacing_lg">20dp</dimen>
    <dimen name="spacing_xl">24dp</dimen>
    <dimen name="spacing_xxl">32dp</dimen>
    <dimen name="spacing_section">24dp</dimen>

    <!-- Card -->
    <dimen name="card_radius">12dp</dimen>
    <dimen name="card_elevation">4dp</dimen>

    <!-- Event Card -->
    <dimen name="event_card_width">160dp</dimen>
    <dimen name="event_card_image_height">100dp</dimen>
    <dimen name="event_card_wide_width">220dp</dimen>
    <dimen name="event_card_wide_image_height">130dp</dimen>

    <!-- Featured Star -->
    <dimen name="star_avatar_size">60dp</dimen>
    <dimen name="star_item_width">80dp</dimen>

    <!-- Banner -->
    <dimen name="banner_height">200dp</dimen>

    <!-- Destination Card -->
    <dimen name="destination_card_width">110dp</dimen>
    <dimen name="destination_card_height">80dp</dimen>

    <!-- Header -->
    <dimen name="header_height">62dp</dimen>
    <dimen name="header_logo_height">28dp</dimen>
    <dimen name="header_icon_size">24dp</dimen>

    <!-- Bottom Nav -->
    <dimen name="bottom_nav_height">56dp</dimen>
    <!--
      Override Material3's internal navigation-bar height (default 80dp → too tall).
      This value is used by NavigationBarItemView inside BottomNavigationView to
      lay out icon + label.  62dp gives just enough room for icon(22dp) + gap(4dp)
      + label(14dp) + top/bottom breathing-room while being noticeably more compact.
    -->
    <dimen name="m3_navigation_bar_height">62dp</dimen>

    <!-- Text sizes -->
    <dimen name="text_xs">10sp</dimen>
    <dimen name="text_sm">12sp</dimen>
    <dimen name="text_base">14sp</dimen>
    <dimen name="text_md">16sp</dimen>
    <dimen name="text_lg">18sp</dimen>
    <dimen name="text_xl">20sp</dimen>
    <dimen name="text_xxl">22sp</dimen>

    <!-- Promo Banner -->
    <dimen name="promo_banner_height">100dp</dimen>

    <!-- Category Chips (from ERD: CATEGORY entity) -->
    <dimen name="category_icon_size">48dp</dimen>
    <dimen name="category_chip_width">72dp</dimen>

    <!-- Status Badge -->
    <dimen name="badge_radius">4dp</dimen>
</resources>
